NODE_ENV=production
PORT=5000
CLIENT_URL=https://lms.example.edu

DB_HOST=mysql
DB_PORT=3306
DB_NAME=ai_smart_lms
DB_USER=lms
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me

JWT_SECRET=change_me_to_a_64_character_random_secret
JWT_EXPIRES=1d

AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
AI_TIMEOUT=30000
AI_MAX_RETRIES=2
AI_BATCH_SIZE=25
MAX_TOKENS=3000
TEMPERATURE=0.2
OPENAI_INPUT_COST_PER_1K=0
OPENAI_OUTPUT_COST_PER_1K=0
GEMINI_INPUT_COST_PER_1K=0
GEMINI_OUTPUT_COST_PER_1K=0
OLLAMA_INPUT_COST_PER_1K=0
OLLAMA_OUTPUT_COST_PER_1K=0

STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_URL=https://lms.example.edu
MAX_FILE_SIZE_MB=200

MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300

CACHE_PROVIDER=memory
CACHE_DEFAULT_TTL_SECONDS=60
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=500
WEB_CONCURRENCY=max
PM2_MAX_MEMORY=512M
