NODE_ENV=staging
PORT=5000
CLIENT_URL=https://staging.example.edu

DB_HOST=staging-mysql
DB_PORT=3306
DB_NAME=ai_smart_lms_staging
DB_USER=lms_staging
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me

JWT_SECRET=change_me_to_a_64_character_random_secret
JWT_EXPIRES=1d

AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
AI_TIMEOUT=30000
AI_MAX_RETRIES=2
AI_BATCH_SIZE=25
MAX_TOKENS=3000
TEMPERATURE=0.2
OPENAI_INPUT_COST_PER_1K=0
OPENAI_OUTPUT_COST_PER_1K=0
GEMINI_INPUT_COST_PER_1K=0
GEMINI_OUTPUT_COST_PER_1K=0
OLLAMA_INPUT_COST_PER_1K=0
OLLAMA_OUTPUT_COST_PER_1K=0

STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_URL=https://staging.example.edu
MAX_FILE_SIZE_MB=200

CACHE_PROVIDER=memory
API_RATE_LIMIT_MAX=300
