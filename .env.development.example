NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_smart_lms
DB_USER=root
DB_PASSWORD=
DB_ROOT_PASSWORD=root_password

JWT_SECRET=replace_with_a_strong_development_secret
JWT_EXPIRES=7d

AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_MODEL=llama3.1
AI_TIMEOUT=30000
AI_MAX_RETRIES=2
AI_BATCH_SIZE=25
MAX_TOKENS=3000
TEMPERATURE=0.2
OPENAI_INPUT_COST_PER_1K=0
OPENAI_OUTPUT_COST_PER_1K=0
GEMINI_INPUT_COST_PER_1K=0
GEMINI_OUTPUT_COST_PER_1K=0
OLLAMA_INPUT_COST_PER_1K=0
OLLAMA_OUTPUT_COST_PER_1K=0

STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_URL=http://localhost:5000
MAX_FILE_SIZE_MB=200

CACHE_PROVIDER=memory
API_RATE_LIMIT_MAX=300
